{
  "version": "0.2.0",
  "configurations": [

    // ── Full pipeline ─────────────────────────────────────────────────────
    {
      "name": "Run Pipeline (NVDA)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/main.py",
      "args": ["NVDA"],
      "console": "integratedTerminal",
      "env": { "PYTHONPATH": "${workspaceFolder}" }
    },
    {
      "name": "Run Pipeline (custom ticker)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/main.py",
