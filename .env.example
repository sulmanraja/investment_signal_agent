# Copy this file to .env and fill in your keys.
# .env is git-ignored; .env.example is tracked.

# ── LLM provider ──────────────────────────────────────────────────────────────
# ollama    (default) — local Ollama; requires `ollama serve` and model pulled
# anthropic           — Claude API via ANTHROPIC_API_KEY; no Ollama needed
AGENT_LLM_PROVIDER=ollama

# Model name — interpreted relative to the active provider:
#   ollama mode:    granite3.3:8b  (or any model you have pulled)
#   anthropic mode: claude-haiku-4-5-20251001  (or claude-sonnet-4-6, etc.)
AGENT_LLM=granite3.3:8b

# ── Embedding provider ────────────────────────────────────────────────────────
# ollama      (default) — nomic-embed-text via local Ollama
# huggingface           — all-MiniLM-L6-v2 runs locally, no Ollama needed
# NOTE: switching providers requires rebuilding the FAISS index (make run-ingest)
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=nomic-embed-text

# ── Tree of Thoughts ──────────────────────────────────────────────────────────
TOT_MAX_DEPTH=2
TOT_BEAM_WIDTH=2

# ── External API keys ─────────────────────────────────────────────────────────
FRED_API_KEY=your_fred_api_key_here        # https://fred.stlouisfed.org/docs/api/api_key.html
NEWSDATA_API_KEY=your_newsdata_key_here    # https://newsdata.io/
GITHUB_TOKEN=your_github_token_here        # https://github.com/settings/tokens (optional, raises rate limit)

# ── Anthropic API key (required when AGENT_LLM_PROVIDER=anthropic) ────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here   # https://console.anthropic.com/
